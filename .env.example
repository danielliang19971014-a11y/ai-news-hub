# Email Configuration
EMAIL_SENDER=your_email@qq.com
EMAIL_PASSWORD=your_qq_smtp_password
EMAIL_RECIPIENT=your_email@qq.com

# SMTP Configuration（可选，覆盖默认 QQ 邮箱设置）
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USERNAME=your_email@qq.com
SMTP_PASSWORD=your_qq_smtp_password
SMTP_USE_TLS=False
SMTP_USE_SSL=True

# Server 酱（微信推送，可选）
SERVERCHAN_KEY=your_serverchan_key

# TLDR RSS 源
TLDR_RSS_URL=https://tldr.tech/api/rss/tech

# The Rundown（暂不可用，保持关闭）
RUNDOWN_ENABLED=False

# macOS 桌面通知
MACOS_NOTIFICATION_ENABLED=True

# Schedule（每天推送时间，24小时制）
SCHEDULE_TIME=08:00

# 调度时区与允许发送窗口
SCHEDULE_TIMEZONE=Asia/Shanghai
SEND_WINDOW_MINUTES=60

# 本机常驻任务只发桌面通知，邮件统一由 GitHub Actions 发送
LOCAL_EMAIL_ENABLED=False

# Logging
LOG_LEVEL=INFO
